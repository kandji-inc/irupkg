# Copy this file to .env and fill in your values.
# docker compose reads .env automatically.

# Required
IRU_API_URL=tenant.api.iru.com
IRUPKG_TOKEN=your-iru-api-token
# KANDJI_API_URL and KANDJI_TOKEN are still accepted but deprecated

# Optional -- when set, Slack notifications are automatically enabled
# SLACK_TOKEN=https://hooks.slack.com/services/...
